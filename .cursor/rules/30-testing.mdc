## Running Tests

```bash
# Run all tests
make test

# Run tests for a specific package
go test ./internal/user/usecase/...

# Run a specific test
go test -run TestUserManager_FindByID ./internal/user/usecase/

# Generate coverage report
make cov
```

## HTTP Handler Integration Tests

Use `httptest` and `gin.TestMode` to test handlers:

```go
import (
    "net/http"
    "net/http/httptest"
    "testing"

    "github.com/gin-gonic/gin"
    "github.com/stretchr/testify/assert"
    "go.uber.org/mock/gomock"
)

func TestUserHandler_Me(t *testing.T) {
    gin.SetMode(gin.TestMode)

    tests := []struct {
        name       string
        userID     string
        mockSetup  func(*mock.MockUserRepository)
        wantStatus int
    }{
        {
            name:   "successfully get user profile",
            userID: "1",
            mockSetup: func(m *mock.MockUserRepository) {
                m.EXPECT().
                    FindByID(gomock.Any(), uint(1)).
                    Return(domain.User{ID: 1, Username: "alice"}, nil)
            },
            wantStatus: http.StatusOK,
        },
        {
            name:   "user not found",
            userID: "999",
            mockSetup: func(m *mock.MockUserRepository) {
                m.EXPECT().
                    FindByID(gomock.Any(), uint(999)).
                    Return(domain.User{}, usecase.ErrUserNotFound)
            },
            wantStatus: http.StatusNotFound,
        },
    }

    for _, tt := range tests {
        t.Run(tt.name, func(t *testing.T) {
            ctrl := gomock.NewController(t)
            defer ctrl.Finish()

            mockRepo := mock.NewMockUserRepository(ctrl)
            tt.mockSetup(mockRepo)

            manager := usecase.NewUserManager(mockRepo, nil)
            handler := handler.NewUserHandler(manager)

            router := gin.New()
            router.GET("/api/user/me", handler.Me)

            req := httptest.NewRequest("GET", "/api/user/me?id="+tt.userID, nil)
            w := httptest.NewRecorder()
            router.ServeHTTP(w, req)

            assert.Equal(t, tt.wantStatus, w.Code)
        })
    }
}
```

## Test Data Factories

Create reusable test data generator functions:

```go
// Basic factory function
func newTestUser(id uint) *domain.User {
    return &domain.User{
        ID:        id,
        Username:  "testuser",
        Email:     "test@example.com",
        CreatedAt: time.Now(),
    }
}

// Factory with options
type UserOption func(*domain.User)

func WithEmail(email string) UserOption {
    return func(u *domain.User) {
        u.Email = email
    }
}

func newTestUserWithOptions(id uint, opts ...UserOption) *domain.User {
    user := newTestUser(id)
    for _, opt := range opts {
        opt(user)
    }
    return user
}

// Usage
user := newTestUserWithOptions(1, WithEmail("custom@example.com"))
```

## Test Manager Helper

```go
// Create a test Manager with mocks
func createTestUserManager(t *testing.T) (
    *usecase.UserManager,
    *mock.MockUserRepository,
    *gomock.Controller,
) {
    ctrl := gomock.NewController(t)
    mockRepo := mock.NewMockUserRepository(ctrl)

    manager := usecase.NewUserManager(mockRepo, nil)
    return manager, mockRepo, ctrl
}

// Usage
func TestUserManager_Method(t *testing.T) {
    manager, mockRepo, ctrl := createTestUserManager(t)
    defer ctrl.Finish()

    mockRepo.EXPECT().FindByID(gomock.Any(), uint(1)).Return(domain.User{ID: 1}, nil)

    result, err := manager.FindByID(context.Background(), 1)
    assert.NoError(t, err)
}
```

## Test File Organization

```
{domain}/
├── usecase/
│   ├── {domain}.go
│   ├── {domain}_test.go      # UseCase unit tests
│   ├── interfaces.go
│   └── mock/
│       └── interfaces.go     # Auto-generated mocks
└── adapter/
    ├── delivery/http/
    │   ├── handler/
    │   │   ├── {domain}.go
    │   │   └── {domain}_test.go  # Handler integration tests
    └── repository/
        ├── {domain}.go
        └── {domain}_test.go      # Repository tests
```

